      "parameters": {
        "jsonSchemaExample": "{\n  \"apply_button\": true,\n  \"easy_apply\": false,\n  \"resume_required\": true,\n  \"cover_letter_required\": false,\n  \"required_fields\": [\n    \"Full Name\",\n    \"Email\",\n    \"Phone\"\n  ],\n  \"custom_questions\": [\n    \"Why do you want to work here?\"\n  ],\n  \"application_url\": \"https://example.com/apply\",\n  \"eligible_from_nigeria\": true,\n  \"eligibility_status\": \"Eligible\",\n  \"eligibility_confidence\": \"High\",\n  \"remote_type\": \"Worldwide\",\n  \"visa_sponsorship\": \"unknown\",\n  \"work_authorization_required\": \"unknown\",\n  \"location\": \"Remote - Worldwide\",\n  \"salary\": \"Not stated\",\n  \"eligibility_reason\": \"The role is explicitly open to worldwide remote applicants.\"\n}"
